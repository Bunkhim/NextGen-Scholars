# Gemini API Key - Each team member should use their own key
# Get your free key at: https://aistudio.google.com/app/apikey
#
# Steps:
# 1. Copy this file and rename to .env
# 2. Replace YOUR_API_KEY_HERE with your actual Gemini API key
# 3. Never commit .env to Git!

# GEMINI_API_KEY=YOUR_API_KEY_HERE

# Google OAuth Web Client ID (required for Google Sign-In)
# This is the "Web application" client ID from Google Cloud Console / Firebase Console.
# It is NOT a secret — it's safe to include here and in client-side code.
# Must match GOOGLE_CLIENT_ID configured in nextgen-api/.env
GOOGLE_WEB_CLIENT_ID=1043004620020-f5cuppbqdlqbfvah6cl4nq7fg709sv6i.apps.googleusercontent.com
